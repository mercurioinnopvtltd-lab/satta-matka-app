# Backend Environment Variables
NODE_ENV=production
PORT=5000
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/satta-matka

# JWT Secrets
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRE=7d

# Payment Gateway
STRIPE_SECRET_KEY=sk_live_your_stripe_key
STRIPE_PUBLIC_KEY=pk_live_your_stripe_key
RAZORPAY_KEY_ID=your_razorpay_key
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Admin Credentials
ADMIN_EMAIL=admin@sattamatka.com
ADMIN_PASSWORD=secure_password_here

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Redis (Optional - for caching)
REDIS_URL=redis://localhost:6379

# Game Settings
GAME_COMMISSION_PERCENTAGE=10
AGENT_COMMISSION_PERCENTAGE=5
WITHDRAWAL_MINIMUM=500
